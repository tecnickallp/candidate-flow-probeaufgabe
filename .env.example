SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
MASTER_ENCRYPTION_KEY=
LLM_PROVIDER=openai

# Optional — Dev-Shortcut (ohne DB-Verschlüsselung):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# AWS Bedrock (LLM_PROVIDER=bedrock):
AWS_BEARER_TOKEN_BEDROCK=
AWS_BEDROCK_REGION=eu-north-1
AWS_BEDROCK_MODEL_ID=eu.anthropic.claude-haiku-4-5-20251001-v1:0
# Alternativen (eu-north-1): eu.anthropic.claude-opus-4-8 (langsamer, stärker)
# Nicht EU-tauglich: eu.anthropic.claude-3-5-haiku-20241022-v1:0 (nur US)

# Heuristik-Fallback wenn kein LLM-Key (lokal testen / Demo ohne API-Key):
USE_HEURISTIC_FALLBACK=true

# --- E-Mail nach abgeschlossener Analyse (ohne eigene Domain) ---
# Empfohlen: Brevo (kostenlos, nur Absender-E-Mail verifizieren, kein DNS)
# 1) https://www.brevo.com → Account anlegen
# 2) Senders → Absender hinzufügen (deine Gmail/Outlook) → Bestätigungslink klicken
# 3) https://app.brevo.com/settings/keys/api → API-Key erstellen
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
EMAIL_FROM=Candidate Flow Analyzer <deine-email@gmail.com>

# Alternative: Gmail/Outlook per SMTP (lokal ok; auf Render evtl. blockiert)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=deine-email@gmail.com
# SMTP_PASSWORD=app-passwort-aus-google-konto
# EMAIL_FROM=Candidate Flow Analyzer <deine-email@gmail.com>

# Alternative: Resend (nur mit verifizierter Domain)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=

# Empfänger Probeaufgabe (Standard):
# LEAD_NOTIFICATION_TO=artur.b@candidate-flow.de
# Lokal ohne Versand (nur Log):
# EMAIL_DRY_RUN=true

# Produktion (Render/Railway): siehe docs/DEPLOY.md
# - SUPABASE_* für persistente DB setzen
# - BREVO_API_KEY + EMAIL_FROM für Lead-Benachrichtigung
# - OPENAI_API_KEY (oder anderer Provider) für bessere Extraktion
# - MASTER_ENCRYPTION_KEY nur wenn Keys über /settings gespeichert werden
