SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
MASTER_ENCRYPTION_KEY=
LLM_PROVIDER=openai

# Optional — Dev-Shortcut (ohne DB-Verschlüsselung):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# AWS Bedrock (LLM_PROVIDER=bedrock):
AWS_BEARER_TOKEN_BEDROCK=
AWS_BEDROCK_REGION=eu-north-1
AWS_BEDROCK_MODEL_ID=eu.anthropic.claude-haiku-4-5-20251001-v1:0
# Alternativen (eu-north-1): eu.anthropic.claude-opus-4-8 (langsamer, stärker)
# Nicht EU-tauglich: eu.anthropic.claude-3-5-haiku-20241022-v1:0 (nur US)

# Heuristik-Fallback wenn kein LLM-Key (lokal testen / Demo ohne API-Key):
USE_HEURISTIC_FALLBACK=true

# Produktion (Render/Railway): siehe docs/DEPLOY.md
# - SUPABASE_* für persistente DB setzen
# - OPENAI_API_KEY (oder anderer Provider) für bessere Extraktion
# - MASTER_ENCRYPTION_KEY nur wenn Keys über /settings gespeichert werden
